/obj/item/paper/fluff/sop
	name = "纸张- '标准操作流程'"
	info = "警报等级：<BR>\n蓝色 - 紧急情况<BR>\n\t1. 由火灾引起<BR>\n\t2. 由人工操作触发<BR>\n\t行动：<BR>\n\t\t关闭所有防火门。只有重置警报后才能开启<BR>\n红色 - 弹射/自毁<BR>\n\t1. 由模块操作电脑触发。<BR>\n\t行动：<BR>\n\t\t在指定时间后，模块将被完全弹出。<BR>\n<BR>\n引擎维护说明：<BR>\n\t关闭点火系统：<BR>\n\t启动内部供电<BR>\n\t启动轨道平衡矩阵<BR>\n\t移除区域内挥发性液体<BR>\n\t穿上防火服<BR>\n<BR>\n\t事后<BR>\n\t\t去污处理<BR>\n\t\t前往接受医检<BR>\n<BR>\n毒素实验室流程：<BR>\n\t无论如何都要佩戴防毒面具<BR>\n\t带上一个氧气瓶。<BR>\n\t启动内部供气<BR>\n<BR>\n\t事后<BR>\n\t\t去污处理<BR>\n\t\t前往接受医检<BR>\n<BR>\n灾害流程：<BR>\n\t火灾：<BR>\n\t\t启动区域火警警报。<BR>\n\t\t移动到安全区域。<BR>\n\t\t穿上防火服<BR>\n\t\t事后：<BR>\n\t\t\t评估损失<BR>\n\t\t\t修复损坏<BR>\n\t\t\t如有需要，撤离<BR>\n\t流星雨：<BR>\n\t\t启动火警警报<BR>\n\t\t移动到飞船后部<BR>\n\t\t事后<BR>\n\t\t\t修复损坏<BR>\n\t\t\t如有需要，撤离<BR>\n\t意外再入：<BR>\n\t\t启动飞船前部火警警报。<BR>\n\t\t将挥发物移到防火区域！<BR>\n\t\t穿上防火服。<BR>\n\t\t保持安全，直到紧急飞船抵达。<BR>\n<BR>\n\t\t如果飞船没有到来 -<BR>\n\t\t\t撤离到附近安全区域！"

